# OpenRouter LLM provider — get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here
BASE_URL=https://openrouter.ai/api/v1

# Default model used for single-run generator calls
LLM_MODEL=openai/gpt-4o-mini

# Model A — quality baseline for evaluation
MODEL_A=openai/gpt-4o-mini

# Model B — free tier for A/B comparison
MODEL_B=arcee-ai/trinity-large-preview:free

# Chainlit auth + persistence
CHAINLIT_AUTH_SECRET=<run: uv run chainlit create-secret>
CHAINLIT_DEFAULT_USER=admin
CHAINLIT_DEFAULT_PASSWORD=admin
DATABASE_URL=sqlite+aiosqlite:///chat_history.db
